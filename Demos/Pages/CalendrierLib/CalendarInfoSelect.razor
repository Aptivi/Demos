@page "/calendrier/calendar/calendarinfo"

<PageTitle>Calendrier - Calendar - Calendar Info - Aptivi Project Demos</PageTitle>

@using System.Threading;
@using System.Net;
@using System.Text;
@using System.IO
@using System.Text.Json
@using Calendrier
@using Demos.Data
@inject IJSRuntime JSRuntime;

<Hero Title="Calendrier - Calendar - Calendar Info">
	You can demonstrate a feature from Calendrier where we showcase this feature,
	and we provide the API documentation here for future reference. This demonstrates the
	"Get calendar info" feature.
</Hero>
<BrandedBorder>
	<p>
		Select calendar type: <InputSelect @bind-Value="Type">
			@foreach (var type in Types)
			{
				<option value="@type">@type</option>
			}
		</InputSelect>
	</p>
	<p>Results from <code>GetCalendar()</code></p>
	@if (Result is not null)
	{
		<ul>
			<li>Name: @Result.Name</li>
			<li>Date (normal): @NormalDate</li>
			<li>Date (calendar): @CalendarDate</li>
			<li>Culture info</li>
			<ul>
				<li>Name: @Result.Culture.DisplayName</li>
				<li>English name: @Result.Culture.EnglishName</li>
				<li>Native name: @Result.Culture.NativeName</li>
				<li>ID: @Result.Culture.Name</li>
			</ul>
		</ul>
    }
    else if (Errored)
    {
        <p>Error obtaining results: @ErrorReason</p>
    }
	<div class="d-grid gap-2 d-sm-flex">
		<button class="btn btn-primary btn-lg" type="button" @onclick="@ClickEvents[0]">Analyze</button>
		<button class="btn btn-primary btn-lg" type="button" @onclick="@ClickEvents[1]">API Reference</button>
	</div>
</BrandedBorder>

@code {
	public CalendarTypes[] Types = Enum.GetValues<CalendarTypes>();
	public CalendarTypes Type { get; set; }
	public bool Errored { get; set; } = false;
	public string ErrorReason { get; set; } = "";
	public BaseCalendar Result { get; set; }
	public string NormalDate { get; set; }
	public string CalendarDate { get; set; }
	public EventCallback[] ClickEvents => [
		EventCallback.Factory.Create(this, ProcessInput),
		EventCallback.Factory.Create(this, new Action(async () => await JSRuntime.InvokeVoidAsync("open", "https://aptivi.github.io/Calendrier/api/Calendrier.CalendarTools.html#Calendrier_CalendarTools_GetCalendar_Calendrier_CalendarTypes_", "_blank"))),
	];

	public void ProcessInput()
	{
		try
		{
			Errored = false;
			Result = CalendarTools.GetCalendar(Type);
			NormalDate = DateTime.Now.ToString();
			CalendarDate = DateTime.Now.ToString(Result.Culture.DateTimeFormat);
		}
        catch (Exception ex)
        {
            Errored = true;
            ErrorReason = ex.Message;
        }
	}
}
