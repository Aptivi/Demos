@page "/colorimetry/colors/colorinfoselect"

<PageTitle>Colorimetry - Colors - Color Info (select) - Aptivi Project Demos</PageTitle>

@using System.Threading;
@using System.Net;
@using System.Text;
@using System.IO
@using System.Text.Json
@using Colorimetry
@using Demos.Data
@inject IJSRuntime JSRuntime;

<Hero Title="Colorimetry - Colors - Color Info (select)">
	You can demonstrate a feature from Colorimetry where we showcase this feature,
	and we provide the API documentation here for future reference. This demonstrates the
	"Get color info" feature with color input type.
</Hero>
<BrandedBorder>
	<div class="mb-3">
		<label class="form-label">Select a color: <input type="color" @bind-value="ColorSpecifier"></input></label>
	</div>
	<p>Results from <code>new Color()</code></p>
	@if (Result is not null)
	{
		<ul>
			<li>Color name: @Result.Name</li>
			<li>Hexadecimal: @Result.Hex</li>
			<li>Normal sequence: @Result.PlainSequence</li>
			<li>Original sequence: @Result.PlainSequenceOriginal</li>
			<li>True color sequence: @Result.PlainSequenceTrueColor</li>
			<li>Color type: @Result.Type</li>
			<li>System.ConsoleColor: @Result.ColorEnum16</li>
			<li>ConsoleColors: @Result.ColorEnum255</li>
			<li>Brightness: @Result.Brightness</li>
        </ul>
    }
    else if (Errored)
    {
        <p>Error obtaining results: @ErrorReason</p>
    }
    <div class="d-grid gap-2 d-sm-flex">
		<button class="btn btn-primary btn-lg" type="button" @onclick="@ClickEvents[0]">Analyze</button>
		<button class="btn btn-primary btn-lg" type="button" @onclick="@ClickEvents[1]">API Reference</button>
	</div>
</BrandedBorder>

@code {
	public string ColorSpecifier { get; set; } = "#FFFFFF";
    public bool Errored { get; set; } = false;
    public string ErrorReason { get; set; } = "";
    public Color Result { get; set; }
    public EventCallback[] ClickEvents => [
        EventCallback.Factory.Create(this, ProcessInput),
		EventCallback.Factory.Create(this, new Action(async () => await JSRuntime.InvokeVoidAsync("open", "https://aptivi.github.io/Colorimetry/api/Colorimetry.Color.html#Colorimetry_Color__ctor_System_String_", "_blank"))),
	];

    public void ProcessInput()
    {
        try
        {
            Errored = false;
			Result = new(ColorSpecifier);
        }
        catch (Exception ex)
        {
            Errored = true;
            ErrorReason = ex.Message;
        }
	}
}
